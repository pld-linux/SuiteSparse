--- SuiteSparse-7.12.2/AMD/CMakeLists.txt.orig	2026-02-10 19:25:51.000000000 +0100
+++ SuiteSparse-7.12.2/AMD/CMakeLists.txt	2026-07-17 18:05:13.076938119 +0200
@@ -76,10 +76,9 @@ include_directories ( Source Include )
 #-------------------------------------------------------------------------------
 
 if ( SUITESPARSE_HAS_FORTRAN )
-    file ( GLOB AMD_SOURCES "Source/*.c" "Source/*.f" )
-else ( )
-    file ( GLOB AMD_SOURCES "Source/*.c" )
+    file ( GLOB AMDF77_SOURCES "Source/*.f" )
 endif ( )
+    file ( GLOB AMD_SOURCES "Source/*.c" )
 
 if ( BUILD_SHARED_LIBS )
     add_library ( AMD SHARED ${AMD_SOURCES} )
@@ -100,6 +99,18 @@ if ( BUILD_SHARED_LIBS )
     target_include_directories ( AMD
         INTERFACE $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/Include>
                   $<INSTALL_INTERFACE:${SUITESPARSE_INCLUDEDIR}> )
+ 
+    if ( SUITESPARSE_HAS_FORTRAN )
+        add_library ( AMDF77 SHARED ${AMDF77_SOURCES} )
+        set_target_properties ( AMDF77 PROPERTIES
+            VERSION ${AMD_VERSION_MAJOR}.${AMD_VERSION_MINOR}.${AMD_VERSION_SUB}
+            C_STANDARD 11
+            C_STANDARD_REQUIRED ON
+            OUTPUT_NAME amdf77
+            SOVERSION ${AMD_VERSION_MAJOR}
+            WINDOWS_EXPORT_ALL_SYMBOLS ON
+            LINKER_LANGUAGE C )
+    endif ( )
 endif ( )
 
 #-------------------------------------------------------------------------------
@@ -128,6 +139,14 @@ if ( BUILD_STATIC_LIBS )
         INTERFACE $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/Include>
                   $<INSTALL_INTERFACE:${SUITESPARSE_INCLUDEDIR}> )
 
+    if ( SUITESPARSE_HAS_FORTRAN )
+        add_library ( AMDF77_static STATIC ${AMDF77_SOURCES} )
+        set_target_properties ( AMDF77_static PROPERTIES
+            C_STANDARD 11
+            C_STANDARD_REQUIRED ON
+            OUTPUT_NAME amdf77
+            LINKER_LANGUAGE C )
+    endif ( )
 endif ( )
 
 #-------------------------------------------------------------------------------
@@ -140,11 +159,20 @@ if ( BUILD_SHARED_LIBS )
     target_include_directories ( AMD PUBLIC
         "$<TARGET_PROPERTY:SuiteSparse::SuiteSparseConfig,INTERFACE_INCLUDE_DIRECTORIES>" )
 endif ( )
+if ( SUITESPARSE_HAS_FORTRAN )
+    target_link_libraries ( AMDF77 PRIVATE ${SUITESPARSE_CONFIG_LIBRARIES} )
+endif ( )
 if ( BUILD_STATIC_LIBS )
     if ( TARGET SuiteSparse::SuiteSparseConfig_static )
         target_link_libraries ( AMD_static PUBLIC SuiteSparse::SuiteSparseConfig_static )
+        if ( SUITESPARSE_HAS_FORTRAN )
+            target_link_libraries ( AMDF77_static PUBLIC SuiteSparse::SuiteSparseConfig_static )
+        endif ( )
     else ( )
         target_link_libraries ( AMD_static PUBLIC SuiteSparse::SuiteSparseConfig )
+        if ( SUITESPARSE_HAS_FORTRAN )
+            target_link_libraries ( AMDF77_static PUBLIC SuiteSparse::SuiteSparseConfig )
+        endif ( )
     endif ( )
 endif ( )
 
@@ -173,6 +201,11 @@ if ( BUILD_SHARED_LIBS )
         RUNTIME DESTINATION ${SUITESPARSE_BINDIR}
         PUBLIC_HEADER DESTINATION ${SUITESPARSE_INCLUDEDIR} )
 
+    if ( SUITESPARSE_HAS_FORTRAN )
+        install ( TARGETS AMDF77
+            LIBRARY DESTINATION ${SUITESPARSE_LIBDIR} )
+    endif ( )
+
     # create (temporary) export target file during build
     export ( EXPORT AMDTargets
         NAMESPACE SuiteSparse::
@@ -189,6 +222,11 @@ if ( BUILD_STATIC_LIBS )
         ARCHIVE DESTINATION ${SUITESPARSE_LIBDIR}
         PUBLIC_HEADER DESTINATION ${SUITESPARSE_INCLUDEDIR} )
 
+    if ( SUITESPARSE_HAS_FORTRAN )
+        install ( TARGETS AMDF77_static
+            ARCHIVE DESTINATION ${SUITESPARSE_LIBDIR} )
+    endif ( )
+
     # create (temporary) export target file during build
     export ( EXPORT AMDTargets_static
         NAMESPACE SuiteSparse::
